# OpenAI API Key (required for DocETL)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=

# Default model override (optional, e.g. gpt-4o-mini or gemini/gemini-2.5-flash)
DOCETL_MODEL=

# Alternative: Azure Document Intelligence (optional, for better PDF parsing)
# DOCUMENTINTELLIGENCE_API_KEY=your_azure_api_key_here
# DOCUMENTINTELLIGENCE_ENDPOINT=your_azure_endpoint_here

# Alternative: Use other LLM providers via LiteLLM
# GEMINI_API_KEY=your_gemini_api_key_here
